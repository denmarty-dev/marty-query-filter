{
    "name": "denmarty/marty-query-filter",
    "description": "Reusable query filter pipeline for Laravel Eloquent builders.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "eloquent",
        "filters",
        "query-filters",
        "pipeline"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/container": "^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "Denmarty\\MartyQueryFilter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Denmarty\\MartyQueryFilter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "lint": "vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Denmarty\\MartyQueryFilter\\MartyQueryFilterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
